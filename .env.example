# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@db:5434/lavrador_team"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-minimum-32-characters"
JWT_REFRESH_SECRET="change-me-refresh-secret-minimum-32-characters"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3333
CORS_ORIGIN="http://localhost:4501","http://localhost:4502"
