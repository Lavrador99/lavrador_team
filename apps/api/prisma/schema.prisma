generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum MovementPattern {
  DOMINANTE_JOELHO
  DOMINANTE_ANCA
  EMPURRAR_HORIZONTAL
  EMPURRAR_VERTICAL
  PUXAR_HORIZONTAL
  PUXAR_VERTICAL
  CORE
  LOCOMOCAO
}

enum Equipment {
  BARRA
  HALTERES
  RACK
  MAQUINAS
  CABO
  KETTLEBELL
  PESO_CORPORAL
  BANCO
  CARDIO_EQ
  SMITH
  RESISTANCE_BAND
  PARALELAS
  BARRA_FIXA
  FOAM_ROLLER
}

enum TrainingLevel {
  INICIANTE
  INTERMEDIO
  AVANCADO
}

enum ProgramStatus {
  ACTIVE
  ARCHIVED
}

enum SelectionType {
  PREFERRED
  REQUIRED
}

enum Role {
  ADMIN
  CLIENT
}

enum SessionType {
  TRAINING
  ASSESSMENT
  FOLLOWUP
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─────────────────────────────────────────
// EXERCISES
// ─────────────────────────────────────────

model Exercise {
  id               String          @id @default(cuid())
  name             String
  pattern          MovementPattern
  primaryMuscles   String[]
  secondaryMuscles String[]
  equipment        Equipment[]
  level            TrainingLevel
  gifUrl           String?
  videoUrl         String?
  clinicalNotes    String[]        @default([])
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  exerciseSelections   ExerciseSelection[]
  preferenceScores     ExercisePreferenceScore[]

  @@unique([name])
  @@map("exercises")
}

// ─────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens  RefreshToken[]
  client         Client?
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@map("users")
}

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromUser User @relation("SentMessages",    fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedMessages", fields: [toUserId],   references: [id], onDelete: Cascade)

  @@map("messages")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  userId    String    @unique
  name      String
  birthDate DateTime?
  phone     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments     Assessment[]
  programs        Program[]
  sessions        Session[]
  workouts        Workout[]
  workoutLogs     WorkoutLog[]
  personalRecords PersonalRecord[]
  invoices        Invoice[]
  habits          Habit[]
  progressPhotos  ProgressPhoto[]
  mealPlans       MealPlan[]

  @@map("clients")
}

// ─────────────────────────────────────────
// PROGRESS PHOTOS
// ─────────────────────────────────────────

model ProgressPhoto {
  id           String    @id @default(cuid())
  clientId     String
  assessmentId String?
  url          String
  angle        String?   // "frente" | "lado" | "costas"
  takenAt      DateTime  @default(now())
  notes        String?
  createdAt    DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("progress_photos")
}

// ─────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  amount      Float
  currency    String        @default("EUR")
  description String
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ─────────────────────────────────────────
// HABITS
// ─────────────────────────────────────────

model Habit {
  id        String     @id @default(cuid())
  clientId  String
  name      String
  icon      String?
  frequency String     @default("DAILY")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  client Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  logs   HabitLog[]

  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_logs")
}

// ─────────────────────────────────────────
// WORKOUT TEMPLATES
// ─────────────────────────────────────────

model WorkoutTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  tags        String[]
  blocks      Json     // WorkoutBlock[]
  createdBy   String   // userId do ADMIN
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workout_templates")
}

// ─────────────────────────────────────────
// ASSESSMENTS
// ─────────────────────────────────────────

model Assessment {
  id        String        @id @default(cuid())
  clientId  String
  level     TrainingLevel
  data      Json
  flags     String[]      @default([])
  createdAt DateTime      @default(now())

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  programs Program[]

  @@map("assessments")
}

// ─────────────────────────────────────────
// PROGRAMS
// ─────────────────────────────────────────

model Program {
  id           String        @id @default(cuid())
  clientId     String
  assessmentId String
  name         String
  status       ProgramStatus @default(ACTIVE)
  phases       Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assessment         Assessment          @relation(fields: [assessmentId], references: [id])
  exerciseSelections ExerciseSelection[]
  sessions           Session[]
  workouts           Workout[]

  @@map("programs")
}

// ─────────────────────────────────────────
// EXERCISE SELECTIONS (80/20)
// ─────────────────────────────────────────

model ExerciseSelection {
  id         String          @id @default(cuid())
  programId  String
  exerciseId String
  pattern    MovementPattern
  type       SelectionType
  createdAt  DateTime        @default(now())

  program  Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([programId, exerciseId])
  @@map("exercise_selections")
}

// ─────────────────────────────────────────
// SESSIONS
// ─────────────────────────────────────────

model Session {
  id          String        @id @default(cuid())
  clientId    String
  programId   String?
  scheduledAt DateTime
  duration    Int           @default(60)
  type        SessionType   @default(TRAINING)
  status      SessionStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  program Program? @relation(fields: [programId], references: [id])

  @@map("sessions")
}

// ─────────────────────────────────────────
// WORKOUTS (plano manual detalhado)
// ─────────────────────────────────────────

enum WorkoutStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Workout {
  id         String        @id @default(cuid())
  programId  String
  clientId   String
  name       String
  dayLabel   String?
  order      Int           @default(0)
  status     WorkoutStatus @default(DRAFT)
  blocks     Json          // WorkoutBlock[]
  durationEstimatedMin Int @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  client  Client       @relation(fields: [clientId],  references: [id], onDelete: Cascade)
  logs    WorkoutLog[]

  @@map("workouts")
}

model WorkoutLog {
  id         String   @id @default(cuid())
  workoutId  String
  clientId   String
  date       DateTime @default(now())
  entries    Json     // WorkoutLogEntry[]
  notes      String?
  durationMin Int?
  rpe        Int?     // 1-10 perceived effort
  createdAt  DateTime @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId],  references: [id], onDelete: Cascade)

  @@map("workout_logs")
}

// ─────────────────────────────────────────
// PERSONAL RECORDS (RMs)
// ─────────────────────────────────────────

enum RecordType {
  WEIGHT_KG    // 1RM / carga máxima (kg)
  REPS_MAX     // máximo de repetições com peso fixo
  ISOMETRIC_S  // duração isométrica (segundos)
  DISTANCE_M   // distância (metros)
  DURATION_S   // duração cardio (segundos)
}

model PersonalRecord {
  id           String     @id @default(cuid())
  clientId     String
  exerciseId   String?    // null = exercício inline (nome livre)
  exerciseName String     // sempre preenchido para display
  type         RecordType
  value        Float      // kg | reps | segundos | metros
  notes        String?
  recordedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("personal_records")
}

// ─────────────────────────────────────────
// AI KNOWLEDGE BASE
// ─────────────────────────────────────────

model AiSystemPrompt {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_system_prompts")
}

model AiKnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_knowledge_docs")
}

// ─────────────────────────────────────────
// SUGGESTION ENGINE (Lavrador-Team Brain)
// ─────────────────────────────────────────

// Registo de preferências do PT — aprende com as escolhas manuais
model ExercisePreferenceScore {
  id             String        @id @default(cuid())
  exerciseId     String
  // Contexto em que o exercício foi escolhido
  level          TrainingLevel
  pattern        MovementPattern
  objective      String        // ex: "HIPERTROFIA", "FORCA", "RESISTENCIA"
  score          Float         @default(1.0)
  timesUsed      Int           @default(1)
  timesRejected  Int           @default(0)  // quando o PT substituiu
  lastUsedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, level, pattern, objective])
  @@map("exercise_preference_scores")
}

// Registo de substituições — quando o PT troca X por Y
model ExerciseSubstitution {
  id           String        @id @default(cuid())
  fromExId     String        // exercício substituído
  toExId       String        // exercício escolhido
  level        TrainingLevel
  reason       String?       // ex: "dor_joelho", "sem_equipamento"
  createdAt    DateTime      @default(now())

  @@map("exercise_substitutions")
}

// ─────────────────────────────────────────
// NUTRITION
// ─────────────────────────────────────────

model Food {
  id       String  @id @default(cuid())
  name     String
  kcal     Float   // per 100g
  protein  Float
  carbs    Float
  fat      Float
  fiber    Float?
  isCustom Boolean @default(false)

  @@map("foods")
}

model MealPlan {
  id        String       @id @default(cuid())
  clientId  String
  name      String
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  client Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  days   MealPlanDay[]

  @@map("meal_plans")
}

model MealPlanDay {
  id        String        @id @default(cuid())
  planId    String
  dayOfWeek Int           // 0=Dom, 1=Seg ... 6=Sáb
  label     String?       // ex: "Segunda"

  plan  MealPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  meals MealPlanMeal[]

  @@unique([planId, dayOfWeek])
  @@map("meal_plan_days")
}

model MealPlanMeal {
  id    String @id @default(cuid())
  dayId String
  name  String // "Pequeno-almoço"
  items Json   // [{foodId, foodName, grams, kcal, protein, carbs, fat}]
  kcal  Float  // calculado

  day MealPlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("meal_plan_meals")
}
