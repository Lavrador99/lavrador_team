{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/lavrador-platform/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_ENV=production next build",
        "cwd": "apps/lavrador-platform"
      },
      "outputs": ["{workspaceRoot}/apps/lavrador-platform/.next/!(cache)/**/*"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --port 4502",
        "cwd": "apps/lavrador-platform"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/lavrador-platform"],
      "options": {
        "jestConfig": "apps/lavrador-platform/jest.config.ts"
      }
    }
  }
}
