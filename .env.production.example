# ─────────────────────────────────────────────────────────────
# LAVRADOR TEAM — Production Environment Variables (API)
# Copy this file as reference when configuring Railway env vars.
# NEVER commit real values.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3333

# Database — get from Supabase project settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis — get from Upstash console or Railway Redis addon
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-32-char-minimum-secret
JWT_REFRESH_SECRET=replace-with-32-char-minimum-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-app.vercel.app

# Email — get from resend.com dashboard
RESEND_API_KEY=re_xxxxxxxxxxxx

# Web Push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Stripe — leave empty or omit to disable payment features
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry — leave empty or omit to disable error tracking
# SENTRY_DSN=https://...

# ─────────────────────────────────────────────────────────────
# LAVRADOR PLATFORM — Production Environment Variables (Frontend)
# Set these in Vercel project settings > Environment Variables.
# ─────────────────────────────────────────────────────────────

# API base URL — Railway service URL
NEXT_PUBLIC_API_URL=https://your-api.railway.app

# VAPID public key (same as API)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Sentry — leave empty to disable
# NEXT_PUBLIC_SENTRY_DSN=https://...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
