{
  "name": "lavrador-team",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api": "nx serve api",
    "web": "nx serve web",
    "dev": "concurrently \"yarn api\" \"yarn web\"",
    "build:api": "nx build api",
    "build:web": "nx build web",
    "db:migrate": "cd apps/api && prisma migrate dev",
    "db:seed": "cd apps/api && ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:studio": "cd apps/api && prisma studio",
    "db:generate": "cd apps/api && prisma generate",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^2.3.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@nx/eslint": "21.1.2",
    "@nx/js": "21.1.2",
    "@nx/nest": "21.1.2",
    "@nx/react": "21.1.2",
    "@nx/vite": "21.1.2",
    "@nx/webpack": "21.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "nx": "21.1.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
