{
  "name": "lavrador-team",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api": "nx serve api",
    "web": "nx serve web",
    "dev": "concurrently \"yarn api\" \"yarn web\"",
    "platform": "nx run lavrador-platform:dev",
    "dev:all": "concurrently \"yarn api\" \"yarn web\" \"yarn platform\"",
    "build:api": "nx build api",
    "build:web": "nx build web",
    "build:lavrador-platform": "nx build lavrador-platform",
    "db:migrate": "cd apps/api && prisma migrate dev",
    "db:seed": "cd apps/api && ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:gif-sync": "cd apps/api && ts-node -r tsconfig-paths/register prisma/wger-gif-sync.ts",
    "db:clear-wger-gifs": "cd apps/api && ts-node -r tsconfig-paths/register prisma/clear-wger-gifs.ts",
    "db:studio": "cd apps/api && prisma studio",
    "db:generate": "cd apps/api && prisma generate",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^2.3.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "framer-motion": "^12.38.0",
    "next": "~15.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io-client": "^4.8.3",
    "styled-components": "^6.1.13",
    "swr": "^2.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@nx/devkit": "21.1.2",
    "@nx/eslint": "21.1.2",
    "@nx/js": "21.1.2",
    "@nx/nest": "21.1.2",
    "@nx/next": "21.1.2",
    "@nx/playwright": "21.1.2",
    "@nx/react": "21.1.2",
    "@nx/vite": "21.1.2",
    "@nx/webpack": "21.1.2",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "10.4.13",
    "concurrently": "^9.1.0",
    "nx": "21.1.2",
    "postcss": "8.4.38",
    "prettier": "^2.6.2",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
